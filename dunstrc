[global]
  title = Dunst
  class = Dunst

  frame_color = "#007d00"
  ;font = 3270Medium Nerd Font Mono 12
  font = Fira Code Light 12

  monitor = 0
  follow = mouse
  geometry = "650x4-25+25"
  indicate_hidden = yes
  shrink = yes

  transparency = 0
  separator_height = 2
  padding = 6
  horizontal_padding = 9
  frame_width = 4


  line_height = 0
  markup = yes
  alignment = left

  idle_threshold = 120
  show_age_threshold = 60
  sort = yes
  word_wrap = yes
  ignore_newline = no
  stack_duplicates = false
  hide_duplicate_count = yes
  show_indicators = no
  sticky_history = no
  history_length = 20
  always_run_script = true
  corner_radius = 0
  icon_position = left
  max_icon_size = 64

  icon_path = /usr/share/icons/Adwaita/16x16/status/:/usr/share/icons/Adwaita/16x16/devices/

  browser = brave-bin

  mouse_left_click = close_current
  mouse_middle_click = do_action
  mouse_right_click = close_all

[urgency_low]
  timeout = 5
  background = "#001100"
  foreground = "#688c69"

[urgency_normal]
  timeout = 8
  background = "#001100"
  foreground = "#d2f7d2"


[urgency_critical]
  timeout = 0
  background = "#003d00"
  foreground = "#ffffff"
